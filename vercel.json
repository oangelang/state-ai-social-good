{
  "rewrites": [
    { "source": "/domains/:slug", "destination": "/domains/index.html" },
    { "source": "/resources",     "destination": "/resources/index.html" },
    { "source": "/ecosystem",     "destination": "/ecosystem/index.html" },
    { "source": "/events",        "destination": "/events/index.html" },
    { "source": "/risks",         "destination": "/risks/index.html" },
    { "source": "/learn",         "destination": "/learn/index.html" },
    { "source": "/admin",         "destination": "/admin/index.html" }
  ],
  "crons": [
    { "path": "/api/daily-research",    "schedule": "0 7 * * *"   },
    { "path": "/api/weekly-validation", "schedule": "0 8 * * 0"   },
    { "path": "/api/monthly-audit",     "schedule": "0 9 1 * *"   }
  ]
}
